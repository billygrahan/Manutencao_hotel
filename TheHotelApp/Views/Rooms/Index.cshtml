
@model TheHotelApp.ViewModels.RoomsAdminIndexViewModel
<!-- Start Page Header -->
<div class="page-header">
    <h1 class="title">Rooms</h1>
    <ol class="breadcrumb">

        <li class="active">View All</li>
    </ol>
    <!-- Start Page Header Right Div -->
    <div class="right">
        <a asp-action="create" class="btn btn-option3 btn-lg">Create New Room</a>
    </div>
</div>
<!-- End Page Header -->
<!-- //////////////////////////////////////////////////////////////////////////// -->
<!-- START CONTAINER -->
<div class="container-padding">
    <!-- Filter Panel -->
    <div class="row">
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-title">
                    <a data-toggle="collapse" href="#filterPanel" aria-expanded="false" aria-controls="filterPanel">
                        Search Filters <span class="caret"></span>
                    </a>
                </div>
                <div id="filterPanel" class="panel-body collapse @(Model.MinPrice.HasValue || Model.MaxPrice.HasValue || Model.Available.HasValue || !string.IsNullOrEmpty(Model.RoomTypeID) ? "in" : "")">
                    <form method="get" asp-action="Index">
                        <div class="row">
                            <div class="col-md-3">
                                <label for="minPrice">Min Price (R$)</label>
                                <input type="number" id="minPrice" name="minPrice" class="form-control" min="0" step="0.01"
                                       value="@Model.MinPrice" placeholder="0.00" />
                            </div>
                            <div class="col-md-3">
                                <label for="maxPrice">Max Price (R$)</label>
                                <input type="number" id="maxPrice" name="maxPrice" class="form-control" min="0" step="0.01"
                                       value="@Model.MaxPrice" placeholder="Any" />
                            </div>
                            <div class="col-md-3">
                                <label for="available">Availability</label>
                                <select id="available" name="available" class="form-control">
                                    <option value="">All</option>
                                    @if (Model.Available == true)
                                    {
                                        <option value="true" selected>Available</option>
                                        <option value="false">Unavailable</option>
                                    }
                                    else if (Model.Available == false)
                                    {
                                        <option value="true">Available</option>
                                        <option value="false" selected>Unavailable</option>
                                    }
                                    else
                                    {
                                        <option value="true">Available</option>
                                        <option value="false">Unavailable</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="roomTypeId">Room Category</label>
                                <select id="roomTypeId" name="roomTypeId" class="form-control">
                                    <option value="">All Categories</option>
                                    @foreach (var rt in Model.RoomTypes)
                                    {
                                        if (Model.RoomTypeID == rt.ID)
                                        {
                                            <option value="@rt.ID" selected>@rt.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@rt.ID">@rt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row" style="margin-top: 12px;">
                            <div class="col-md-12">
                                <button type="submit" class="btn btn-option3">Search</button>
                                <a asp-action="Index" class="btn btn-default">Clear Filters</a>
                                <span class="text-muted" style="margin-left: 12px;">
                                    @Model.Rooms.Count room(s) found
                                </span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Start Row -->
    <div class="row">
        <!-- Start Panel -->
        <div class="col-md-12">
            <div class="panel panel-default">
                <div class="panel-title">
                    Rooms
                </div>
                <div class="panel-body table-responsive">
                    <table id="example0" class="table-bordered display">
                        <thead>
                            <tr>
                                <th>Number</th>
                                <th>Price</th>
                                <th>Available</th>
                                <th>Description</th>
                                <th>Maximum Guests</th>
                                <th>Room Category</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Rooms)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Number)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Price)
                                    </td>
                                    <td>
                                        @Html.Raw(item.Available == true ? "Yes" : "No")
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.Description)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.MaximumGuests)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.RoomType.Name)
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                                        <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                                        @{
                                            if (item.Available == true)
                                            {
                                                <a asp-action="Create" asp-controller="Bookings" asp-route-roomID="@item.ID">Book |</a>
                                            }
                                            else
                                            {
                                                <span>Booked |</span>

                                                }
                                            }

                                            <a asp-action="Delete" data-room-id="@item.ID" data-room-number="@item.Number" data-toggle="modal" data-target="#DeleteModal">Delete</a>
                                        </td>
                                    </tr>
                                        }
                                    </tbody>
                                </table>

                            </div>
                        </div>
                    </div>
                    <!-- End Panel -->
                </div>
                <!-- End Row -->
            </div>
            <!-- END CONTAINER -->
            <!-- DeleteModal -->
            <div class="modal fade" id="DeleteModal" role="dialog">
                <div class="modal-dialog">

                    <!-- Modal content-->
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                            <h4 class="modal-title">Delete Room?</h4>
                        </div>
                        <div class="modal-body">
                            <p id="DeleteConfirmation"></p>
                        </div>
                        <div class="modal-footer">
                            <form asp-action="Delete" method="post">
                                <input type="hidden" name="id" value="" />
                                <input type="submit" value="Delete" class="btn btn-success" />
                                <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
                            </form>
                        </div>
                    </div>

                </div>
            </div> <!-- DeleteModal -->



            @section Scripts{
                <!-- ================================================
                Data Tables
                ================================================ -->
                <script src="~/js/datatables/datatables.min.js"></script>

                <script>
                    $(document).ready(function () {
                        $('#example0').DataTable();
                    });</script>

                <script>
                    $(document).ready(function () {
                        var table = $('#example').DataTable({
                            "columnDefs": [
                                { "visible": false, "targets": 2 }
                            ],
                            "order": [[2, 'asc']],
                            "displayLength": 25,
                            "drawCallback": function (settings) {
                                var api = this.api();
                                var rows = api.rows({ page: 'current' }).nodes();
                                var last = null;

                                api.column(2, { page: 'current' }).data().each(function (group, i) {
                                    if (last !== group) {
                                        $(rows).eq(i).before(
                                            '<tr class="group"><td colspan="5">' + group + '</td></tr>'
                                        );

                                        last = group;
                                    }
                                });
                            }
                        });

                        // Order by the grouping
                        $('#example tbody').on('click', 'tr.group', function () {
                            var currentOrder = table.order()[0];
                            if (currentOrder[0] === 2 && currentOrder[1] === 'asc') {
                                table.order([2, 'desc']).draw();
                            }
                            else {
                                table.order([2, 'asc']).draw();
                            }
                        });
                    });

                    $('#DeleteModal').on('show.bs.modal', function (e) {

                        //get data-id attribute of the clicked element
                        var roomID = $(e.relatedTarget).data('room-id');
                        var roomNumber = $(e.relatedTarget).data('room-number');
                        var deleteMessage = "Are you sure you want to delete room with room no: " + roomNumber + "?";
                        $('#DeleteConfirmation').html(deleteMessage);
                        $(e.currentTarget).find('input[name="id"]').val(roomID);
                    });</script>

            }
